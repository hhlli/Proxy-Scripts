#!/bin/sh
# AnyTLS 高级服务端 一键管理脚本 (基于 Sing-box)
# 兼容: Debian/Ubuntu, RHEL/CentOS/AlmaLinux, Alpine Linux, Arch Linux

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ============================================================
# 系统检测层
# ============================================================

detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_ID="$ID"
        OS_ID_LIKE="$ID_LIKE"
    elif [ -f /etc/alpine-release ]; then
        OS_ID="alpine"
    elif [ -f /etc/arch-release ]; then
        OS_ID="arch"
    else
        OS_ID="unknown"
    fi

    case "$OS_ID" in
        ubuntu|debian|raspbian) PKG_MGR="apt" ;;
        alpine)                 PKG_MGR="apk" ;;
        arch|manjaro)           PKG_MGR="pacman" ;;
        fedora)                 PKG_MGR="dnf" ;;
        centos|rhel|almalinux|rocky|ol)
            if command -v dnf >/dev/null 2>&1; then
                PKG_MGR="dnf"
            else
                PKG_MGR="yum"
            fi
            ;;
        *)
            # 按 ID_LIKE 二次推断
            case "$OS_ID_LIKE" in
                *debian*|*ubuntu*) PKG_MGR="apt" ;;
                *rhel*|*fedora*)
                    command -v dnf >/dev/null 2>&1 && PKG_MGR="dnf" || PKG_MGR="yum" ;;
                *) PKG_MGR="unknown" ;;
            esac
            ;;
    esac
}

detect_init() {
    if command -v systemctl >/dev/null 2>&1 && systemctl --version >/dev/null 2>&1; then
        INIT_SYS="systemd"
    elif command -v rc-service >/dev/null 2>&1; then
        INIT_SYS="openrc"
    elif [ -d /etc/sv ]; then
        INIT_SYS="runit"
    else
        INIT_SYS="sysv"
    fi
}

pkg_install() {
    # 用法: pkg_install curl tar wget
    case "$PKG_MGR" in
        apt)
            apt-get update -y -qq
            apt-get install -y -qq "$@"
            ;;
        apk)
            apk update -q
            apk add -q "$@"
            ;;
        pacman)
            pacman -Sy --noconfirm --needed "$@" >/dev/null
            ;;
        dnf)
            dnf install -y -q "$@"
            ;;
        yum)
            yum install -y -q "$@"
            ;;
        *)
            echo -e "${RED}无法识别包管理器，请手动安装: $*${NC}"
            return 1
            ;;
    esac
}

# ============================================================
# 服务管理抽象层
# ============================================================

SERVICE_NAME="anytls"
OPENRC_INIT="/etc/init.d/${SERVICE_NAME}"

svc_install_unit() {
    # 写入服务单元（systemd / openrc / runit）
    case "$INIT_SYS" in
        systemd)
            cat > /etc/systemd/system/${SERVICE_NAME}.service << 'EOF'
[Unit]
Description=AnyTLS Server Service (Sing-box Core)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/etc/anytls
ExecStart=/usr/local/bin/anytls-server run -c /etc/anytls/config.json
Restart=on-failure
RestartSec=5s
LimitNOFILE=512000

[Install]
WantedBy=multi-user.target
EOF
            systemctl daemon-reload
            systemctl enable ${SERVICE_NAME} 2>/dev/null
            ;;
        openrc)
            cat > "$OPENRC_INIT" << 'EOF'
#!/sbin/openrc-run
description="AnyTLS Server Service (Sing-box Core)"
command="/usr/local/bin/anytls-server"
command_args="run -c /etc/anytls/config.json"
command_background=true
pidfile="/run/${RC_SVCNAME}.pid"
output_log="/var/log/anytls.log"
error_log="/var/log/anytls.log"

depend() {
    need net
}
EOF
            chmod +x "$OPENRC_INIT"
            rc-update add ${SERVICE_NAME} default 2>/dev/null
            ;;
        runit)
            mkdir -p /etc/sv/${SERVICE_NAME}
            cat > /etc/sv/${SERVICE_NAME}/run << 'EOF'
#!/bin/sh
exec /usr/local/bin/anytls-server run -c /etc/anytls/config.json 2>&1
EOF
            chmod +x /etc/sv/${SERVICE_NAME}/run
            ln -sf /etc/sv/${SERVICE_NAME} /var/service/${SERVICE_NAME} 2>/dev/null
            ;;
        sysv)
            cat > /etc/init.d/${SERVICE_NAME} << 'EOF'
#!/bin/sh
### BEGIN INIT INFO
# Provides:          anytls
# Required-Start:    $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
### END INIT INFO
DAEMON=/usr/local/bin/anytls-server
ARGS="run -c /etc/anytls/config.json"
PIDFILE=/var/run/anytls.pid
case "$1" in
    start) start-stop-daemon --start --background --make-pidfile --pidfile $PIDFILE --exec $DAEMON -- $ARGS ;;
    stop)  start-stop-daemon --stop --pidfile $PIDFILE ;;
    restart) $0 stop; sleep 1; $0 start ;;
    *) echo "Usage: $0 {start|stop|restart}" ;;
esac
EOF
            chmod +x /etc/init.d/${SERVICE_NAME}
            update-rc.d ${SERVICE_NAME} defaults 2>/dev/null || true
            ;;
    esac
}

svc_start() {
    case "$INIT_SYS" in
        systemd) systemctl start ${SERVICE_NAME} ;;
        openrc)  rc-service ${SERVICE_NAME} start ;;
        runit)   sv start ${SERVICE_NAME} ;;
        sysv)    /etc/init.d/${SERVICE_NAME} start ;;
    esac
}

svc_stop() {
    case "$INIT_SYS" in
        systemd) systemctl stop ${SERVICE_NAME} 2>/dev/null ;;
        openrc)  rc-service ${SERVICE_NAME} stop 2>/dev/null ;;
        runit)   sv stop ${SERVICE_NAME} 2>/dev/null ;;
        sysv)    /etc/init.d/${SERVICE_NAME} stop 2>/dev/null ;;
    esac
}

svc_restart() {
    case "$INIT_SYS" in
        systemd) systemctl restart ${SERVICE_NAME} ;;
        openrc)  rc-service ${SERVICE_NAME} restart ;;
        runit)   sv restart ${SERVICE_NAME} ;;
        sysv)    /etc/init.d/${SERVICE_NAME} restart ;;
    esac
}

svc_is_active() {
    case "$INIT_SYS" in
        systemd) systemctl is-active --quiet ${SERVICE_NAME} ;;
        openrc)  rc-service ${SERVICE_NAME} status 2>/dev/null | grep -q started ;;
        runit)   sv status ${SERVICE_NAME} 2>/dev/null | grep -q "^run:" ;;
        sysv)    [ -f /var/run/anytls.pid ] && kill -0 "$(cat /var/run/anytls.pid)" 2>/dev/null ;;
    esac
}

svc_disable() {
    case "$INIT_SYS" in
        systemd) systemctl disable ${SERVICE_NAME} 2>/dev/null ;;
        openrc)  rc-update del ${SERVICE_NAME} 2>/dev/null ;;
        runit)   rm -f /var/service/${SERVICE_NAME} 2>/dev/null ;;
        sysv)    update-rc.d ${SERVICE_NAME} remove 2>/dev/null || true ;;
    esac
}

svc_remove_unit() {
    case "$INIT_SYS" in
        systemd)
            rm -f /etc/systemd/system/${SERVICE_NAME}.service
            systemctl daemon-reload
            ;;
        openrc) rm -f "$OPENRC_INIT" ;;
        runit)  rm -rf /etc/sv/${SERVICE_NAME} ;;
        sysv)   rm -f /etc/init.d/${SERVICE_NAME} ;;
    esac
}

svc_logs() {
    case "$INIT_SYS" in
        systemd) journalctl -u ${SERVICE_NAME} -e ;;
        openrc|sysv)
            LOG="/var/log/anytls.log"
            if [ -f "$LOG" ]; then
                tail -100 "$LOG" | less
            else
                echo -e "${YELLOW}日志文件 $LOG 尚不存在。${NC}"
            fi
            ;;
        runit)
            if command -v svlogd >/dev/null 2>&1 && [ -d /etc/sv/${SERVICE_NAME}/log ]; then
                tail -100 /etc/sv/${SERVICE_NAME}/log/current | less
            else
                echo -e "${YELLOW}日志尚未配置，请手动查看 /var/log/anytls.log${NC}"
            fi
            ;;
    esac
}

# ============================================================
# 工具函数
# ============================================================

get_ip() {
    VPS_IP=$(curl -s4 -m 5 api.ipify.org 2>/dev/null \
          || curl -s4 -m 5 ifconfig.me 2>/dev/null \
          || echo "获取失败_请手动替换IP")
}

random_password() {
    # 兼容 busybox tr（Alpine）
    tr -dc 'A-Za-z0-9' < /dev/urandom 2>/dev/null | head -c 16 \
    || cat /proc/sys/kernel/random/uuid 2>/dev/null | tr -dc 'A-Za-z0-9' | head -c 16 \
    || echo "ChangeMeNow$(date +%s)"
}

root_check() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}错误: 必须使用 root 权限运行此脚本!${NC}"
        exit 1
    fi
}

# ============================================================
# 核心功能
# ============================================================

CONF="/etc/anytls/config.json"

check_status() {
    if [ -f "/usr/local/bin/anytls-server" ]; then
        if svc_is_active; then
            echo -e "AnyTLS 状态: ${GREEN}运行中 (Sing-box 核心 / $INIT_SYS)${NC}"
        else
            echo -e "AnyTLS 状态: ${YELLOW}已安装，但未运行${NC}"
        fi
    else
        echo -e "AnyTLS 状态: ${RED}未安装${NC}"
    fi
}

view_config() {
    if [ ! -f "$CONF" ]; then
        echo -e "${RED}配置文件不存在，请先安装!${NC}"
        return
    fi

    get_ip
    PORT=$(grep '"listen_port":' "$CONF" | awk -F: '{print $NF}' | tr -d '", ')
    PASSWORD=$(grep '"password":' "$CONF" | awk -F'"' '{print $4}')
    DOMAIN=$(grep '"server_name":' "$CONF" | awk -F'"' '{print $4}')

    echo -e "${GREEN}=== 当前 AnyTLS 配置 ===${NC}"
    echo -e "节点IP:   ${YELLOW}${VPS_IP}${NC}"
    echo -e "监听端口: ${YELLOW}${PORT}${NC}"
    echo -e "Password: ${YELLOW}${PASSWORD}${NC}"
    echo -e "域名/SNI: ${YELLOW}${DOMAIN}${NC}"
    echo -e "----------------------------------------"
    echo -e "Surge 配置参考:"
    echo -e "${GREEN}AnyTLS-Node = anytls, ${DOMAIN}, ${PORT}, password=${PASSWORD}, sni=${DOMAIN}${NC}"
    echo -e "Init系统:  ${CYAN}${INIT_SYS}${NC} | 包管理器: ${CYAN}${PKG_MGR}${NC}"
}

download_and_replace_core() {
    TARGET_VERSION="$1"
    echo -e "${CYAN}开始下载 Sing-box 核心 (v${TARGET_VERSION})...${NC}"

    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64)  SB_ARCH="amd64" ;;
        aarch64|arm64) SB_ARCH="arm64" ;;
        armv7l)  SB_ARCH="armv7" ;;
        s390x)   SB_ARCH="s390x" ;;
        *)
            echo -e "${RED}不支持的 CPU 架构: $ARCH${NC}"
            exit 1
            ;;
    esac

    URL="https://github.com/SagerNet/sing-box/releases/download/v${TARGET_VERSION}/sing-box-${TARGET_VERSION}-linux-${SB_ARCH}.tar.gz"

    # 确保下载工具可用
    pkg_install curl tar wget 2>/dev/null

    TMP_DIR=$(mktemp -d)
    if command -v wget >/dev/null 2>&1; then
        wget -q -O "${TMP_DIR}/sb.tar.gz" "$URL"
    else
        curl -fsSL -o "${TMP_DIR}/sb.tar.gz" "$URL"
    fi

    tar -xzf "${TMP_DIR}/sb.tar.gz" -C "$TMP_DIR/"
    svc_stop 2>/dev/null
    mv "${TMP_DIR}"/sing-box-*/sing-box /usr/local/bin/anytls-server
    chmod +x /usr/local/bin/anytls-server
    rm -rf "$TMP_DIR"

    echo -e "${GREEN}Sing-box 核心下载完成。${NC}"
}

get_latest_version() {
    VER=$(curl -s https://api.github.com/repos/SagerNet/sing-box/releases/latest \
          | grep '"tag_name":' | sed 's/.*"v\([^"]*\)".*/\1/')
    echo "${VER:-1.11.4}"
}

apply_cert() {
    DOMAIN="$1"
    # 按优先级复用现有证书
    for DIR in /etc/hysteria/certs /etc/tuic/certs; do
        if [ -f "${DIR}/server.crt" ] && [ -f "${DIR}/server.key" ]; then
            echo -e "${GREEN}检测到现有证书 (${DIR})，直接复用。${NC}"
            CERT_PATH="${DIR}/server.crt"
            KEY_PATH="${DIR}/server.key"
            return 0
        fi
    done

    echo -e "${YELLOW}未找到可用证书，开始申请 acme.sh 证书...${NC}"
    pkg_install socat curl 2>/dev/null

    curl -fsSL https://get.acme.sh | sh -s email="admin@${DOMAIN}"
    ACME="$HOME/.acme.sh/acme.sh"
    "$ACME" --issue -d "$DOMAIN" --standalone --force || {
        echo -e "${RED}证书申请失败！请检查域名解析和 80 端口。${NC}"
        exit 1
    }
    mkdir -p /etc/anytls/certs
    "$ACME" --install-cert -d "$DOMAIN" \
        --key-file /etc/anytls/certs/server.key \
        --fullchain-file /etc/anytls/certs/server.crt
    CERT_PATH="/etc/anytls/certs/server.crt"
    KEY_PATH="/etc/anytls/certs/server.key"
}

write_config() {
    mkdir -p /etc/anytls
    cat > "$CONF" << EOF
{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "anytls",
      "tag": "anytls-in",
      "listen": "::",
      "listen_port": ${PORT},
      "users": [
        {
          "name": "user",
          "password": "${PASSWORD}"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "${DOMAIN}",
        "certificate_path": "${CERT_PATH}",
        "key_path": "${KEY_PATH}"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ]
}
EOF
}

install_anytls() {
    if [ -f "$CONF" ]; then
        OLD_DOMAIN=$(grep '"server_name":' "$CONF" | awk -F'"' '{print $4}')
        OLD_PORT=$(grep '"listen_port":' "$CONF" | awk -F: '{print $NF}' | tr -d '", ')
        echo -e "${YELLOW}检测到已有配置 (域名: ${OLD_DOMAIN}, 端口: ${OLD_PORT})。${NC}"
        printf "是否保留现有配置，仅执行核心更新？(Y/n，默认保留): "
        read -r KEEP_CONF
        KEEP_CONF="${KEEP_CONF:-Y}"

        case "$KEEP_CONF" in
            [Yy]*)
                LATEST=$(get_latest_version)
                download_and_replace_core "$LATEST"
                svc_start
                echo -e "${GREEN}核心更新完成，配置已保留！${NC}"
                view_config
                return
                ;;
        esac
    fi

    printf "设置域名 (请输入域名): "
    read -r DOMAIN
    printf "设置端口 (默认 4430): "
    read -r PORT
    PORT="${PORT:-4430}"

    echo -e "${YELLOW}正在生成强密码...${NC}"
    PASSWORD=$(random_password)

    LATEST=$(get_latest_version)
    download_and_replace_core "$LATEST"
    apply_cert "$DOMAIN"
    write_config

    svc_install_unit
    svc_restart

    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}AnyTLS (Sing-box 核心) 安装成功!${NC}"
    view_config
    echo -e "${GREEN}========================================${NC}"
}

modify_config() {
    if [ ! -f "$CONF" ]; then
        echo -e "${RED}配置文件不存在，请先安装!${NC}"
        return
    fi

    printf "设置新端口: "
    read -r NEW_PORT
    NEW_PASSWORD=$(random_password)

    # 使用 sed 兼容 POSIX（不依赖 -E 在所有平台一致）
    sed -i "s/\"listen_port\": [0-9]*/\"listen_port\": ${NEW_PORT}/" "$CONF"
    sed -i "s/\"password\": \"[^\"]*\"/\"password\": \"${NEW_PASSWORD}\"/" "$CONF"

    svc_restart
    echo -e "${GREEN}配置已更新并重启服务。${NC}"
    view_config
}

uninstall_anytls() {
    printf "确认卸载 AnyTLS? (y/N): "
    read -r CONFIRM
    case "$CONFIRM" in
        [Yy]*)
            echo -e "${YELLOW}正在卸载 AnyTLS...${NC}"
            svc_stop
            svc_disable
            svc_remove_unit
            rm -f /usr/local/bin/anytls-server
            rm -rf /etc/anytls
            echo -e "${GREEN}卸载完成。${NC}"
            ;;
        *)
            echo -e "${YELLOW}已取消。${NC}"
            ;;
    esac
}

check_update() {
    echo -e "${CYAN}--- 版本检查 ---${NC}"

    if [ -f "/usr/local/bin/anytls-server" ]; then
        LOCAL_VER=$(/usr/local/bin/anytls-server version 2>/dev/null | head -n 1 | awk '{print $3}')
        echo -e "本地 Sing-box 核心版本: ${LOCAL_VER:-未知}"
    else
        echo -e "${RED}未安装 AnyTLS。${NC}"
        LOCAL_VER="未知"
    fi

    echo -e "${YELLOW}正在获取最新版本信息...${NC}"
    LATEST_SB=$(get_latest_version)
    echo -e "Sing-box GitHub 最新版本: ${LATEST_SB:-获取失败}"

    LATEST_ANYTLS=$(curl -s https://api.github.com/repos/anytls/anytls-rs/releases/latest \
                    | grep '"tag_name":' | sed 's/.*"v\{0,1\}\([^"]*\)".*/\1/')
    echo -e "AnyTLS 协议库最新版本: ${LATEST_ANYTLS:-获取失败}"

    echo -e "${CYAN}----------------${NC}"

    if [ "$LOCAL_VER" != "$LATEST_SB" ] && [ -n "$LATEST_SB" ] && [ "$LOCAL_VER" != "未知" ]; then
        echo -e "${YELLOW}发现 Sing-box 核心新版本 (v${LATEST_SB})！${NC}"
        printf "是否立即保留配置并更新核心？(y/N): "
        read -r DO_UPDATE
        case "$DO_UPDATE" in
            [Yy]*)
                download_and_replace_core "$LATEST_SB"
                svc_start
                echo -e "${GREEN}核心更新成功！${NC}"
                view_config
                ;;
        esac
    elif [ "$LOCAL_VER" = "$LATEST_SB" ]; then
        echo -e "${GREEN}当前核心已是最新版本。${NC}"
    fi
}

# ============================================================
# 主菜单
# ============================================================

root_check
detect_os
detect_init

while true; do
    clear
    echo -e "${GREEN}AnyTLS 一键管理脚本 (Sing-box 核心)${NC}"
    echo -e "系统: ${CYAN}${OS_ID}${NC} | Init: ${CYAN}${INIT_SYS}${NC} | 包管理: ${CYAN}${PKG_MGR}${NC}"
    check_status
    echo "--------------------------------"
    echo "1. 安装 / 覆盖安装"
    echo "2. 卸载"
    echo "3. 重启服务"
    echo "4. 查看日志"
    echo "5. 查看当前配置"
    echo "6. 修改端口和密码"
    echo "7. 检查更新"
    echo "8. 退出"
    printf "请选择 [1-8]: "
    read -r opt

    echo ""
    case "$opt" in
        1) install_anytls ;;
        2) uninstall_anytls ;;
        3) svc_restart && echo -e "${GREEN}已重启。${NC}" ;;
        4) svc_logs ;;
        5) view_config ;;
        6) modify_config ;;
        7) check_update ;;
        8) echo -e "${CYAN}已退出。${NC}"; exit 0 ;;
        *) echo -e "${RED}无效选择。${NC}" ;;
    esac

    echo ""
    printf "按回车键返回主菜单..."
    read -r _
done
